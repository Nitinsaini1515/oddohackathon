NODE_ENV=development
PORT=5000

# MongoDB Atlas (replace with your connection string)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/AssetFlow?retryWrites=true&w=majority

# JWT Secrets (generate strong random strings for production)
JWT_ACCESS_SECRET=your_access_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173
